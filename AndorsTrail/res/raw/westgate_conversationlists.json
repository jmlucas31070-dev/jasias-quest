[
  {
    "id": "wg_realtor_greet",
    "message": "Welcome to Westgate Heights! I'm Mira Penhollow, the licensed realtor for these fine properties. Just outside Ados west gate you'll find four homes I'm authorized to sell. Each is yours forever once the deed changes hands. Care to hear about them?",
    "replies": [
      {"text": "Tell me about the 1-room cottage (5000 gold).", "next_phrase_id": "wg_realtor_buy1"},
      {"text": "Tell me about the 2-room house (12000 gold).", "next_phrase_id": "wg_realtor_buy2"},
      {"text": "Tell me about the 3-room manor (25000 gold).", "next_phrase_id": "wg_realtor_buy3"},
      {"text": "Tell me about the 4-room estate (50000 gold).", "next_phrase_id": "wg_realtor_buy4"},
      {"text": "Maybe later.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },
  {
    "id": "wg_realtor_buy1",
    "message": "A snug cottage with a sewing nook - perfect for a traveling tailor. Comes furnished with a sewing machine. 5000 gold. Have we a deal?",
    "replies": [
      {"text": "Yes, I'll take it. (Pay 5000 gold)", "requires": [{"requireType": "inventory_remove", "id": "gold", "value": 5000}], "rewards": [{"rewardType": "give_item", "id": "wg_deed_home1"}, {"rewardType": "questProgress", "id": "wg_quest_home", "value": 10}], "next_phrase_id": "wg_realtor_thanks"},
      {"text": "Show me the others.", "next_phrase_id": "wg_realtor_greet"},
      {"text": "Not yet.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },
  {
    "id": "wg_realtor_buy2",
    "message": "A two-room house with a sewing room AND a stone hearth for cooking. Excellent for an adventurer who likes a hot meal at home. 12000 gold.",
    "replies": [
      {"text": "Yes, I'll take it. (Pay 12000 gold)", "requires": [{"requireType": "inventory_remove", "id": "gold", "value": 12000}], "rewards": [{"rewardType": "give_item", "id": "wg_deed_home2"}, {"rewardType": "questProgress", "id": "wg_quest_home", "value": 20}], "next_phrase_id": "wg_realtor_thanks"},
      {"text": "Show me the others.", "next_phrase_id": "wg_realtor_greet"},
      {"text": "Not yet.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },
  {
    "id": "wg_realtor_buy3",
    "message": "Three rooms: a craft hall with sewing AND a forge, a kitchen with stove, and a private garden plot in back. Grow your own food! 25000 gold.",
    "replies": [
      {"text": "Yes, I'll take it. (Pay 25000 gold)", "requires": [{"requireType": "inventory_remove", "id": "gold", "value": 25000}], "rewards": [{"rewardType": "give_item", "id": "wg_deed_home3"}, {"rewardType": "questProgress", "id": "wg_quest_home", "value": 30}], "next_phrase_id": "wg_realtor_thanks"},
      {"text": "Show me the others.", "next_phrase_id": "wg_realtor_greet"},
      {"text": "Not yet.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },
  {
    "id": "wg_realtor_buy4",
    "message": "The crown jewel - four rooms, full forge, sewing hall, kitchen, expanded garden, AND a private butler who can fetch goods from any of our market stalls at a discount. 50000 gold.",
    "replies": [
      {"text": "Yes, I'll take it. (Pay 50000 gold)", "requires": [{"requireType": "inventory_remove", "id": "gold", "value": 50000}], "rewards": [{"rewardType": "give_item", "id": "wg_deed_home4"}, {"rewardType": "questProgress", "id": "wg_quest_home", "value": 40}], "next_phrase_id": "wg_realtor_thanks"},
      {"text": "Show me the others.", "next_phrase_id": "wg_realtor_greet"},
      {"text": "Not yet.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },
  {
    "id": "wg_realtor_thanks",
    "message": "Excellent! The keys are yours. Welcome home, neighbor. Through the door behind me you can enter your new property anytime.",
    "replies": [
      {"text": "Thank you.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },

  {
    "id": "wg_seamstress_greet",
    "message": "Threads, needles, fine cloth - everything for the discerning tailor. Cloth and dyes in your bag, a sewing machine in your home, and you can sew yourself a wardrobe. What can I sell you?",
    "replies": [
      {"text": "Show me your cloth and supplies.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_seamstress"},
      {"text": "How does sewing work?", "next_phrase_id": "wg_seamstress_help"},
      {"text": "Goodbye.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },
  {
    "id": "wg_seamstress_help",
    "message": "Buy linen, wool, or silk cloth, plus thread and a needle. Take them to the sewing machine in your home. Each pattern needs different supplies - the machine will tell you what fits. You can sew hoods, tunics, gloves, scarves, even fine boots.",
    "replies": [
      {"text": "Show me your wares.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_seamstress"},
      {"text": "Thanks.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },

  {
    "id": "wg_grocer_greet",
    "message": "Fresh from this morning! Flour, milk, eggs, butter, salt, sugar - all the staples for a working kitchen. Cook 'em up at your stove for hearty meals.",
    "replies": [
      {"text": "Show me your goods.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_grocer"},
      {"text": "I'll come back.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },

  {
    "id": "wg_farmer_greet",
    "message": "Name's Old Tomek. Best seeds west of Crossglen. Plant 'em in your garden plot, give 'em two days to grow, then harvest. Bigger plots, bigger harvests.",
    "replies": [
      {"text": "Show me your seeds.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_farmer"},
      {"text": "How does planting work?", "next_phrase_id": "wg_farmer_help"},
      {"text": "Goodbye.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },
  {
    "id": "wg_farmer_help",
    "message": "Step on a tilled plot in your garden, use a seed from your bag. Forty-eight hours of real time later the crop is ready to harvest. Don't forget about it - some plants wilt if you leave 'em too long.",
    "replies": [
      {"text": "Got it. Show me the seeds.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_farmer"},
      {"text": "Thanks.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },

  {
    "id": "wg_farmersmarket_greet",
    "message": "Fresh harvest from the surrounding farms! Vegetables, fruits, herbs - all picked this week. Good for cooking, good for eating raw.",
    "replies": [
      {"text": "Show me your produce.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_market"},
      {"text": "Goodbye.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },

  {
    "id": "wg_weaponer_greet",
    "message": "Steel, iron, bronze - the makings of a fine blade. I sell ingots and grips. Bring 'em to a forge and you can hammer out a sword that's truly your own.",
    "replies": [
      {"text": "Show me your stock.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_weaponer"},
      {"text": "Goodbye.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },

  {
    "id": "wg_armorer_greet",
    "message": "Shield rims, ring bands, ingots of every metal - the bones of armor and trinkets. Forge yourself a shield or a band of power.",
    "replies": [
      {"text": "Show me your stock.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_armorer"},
      {"text": "Goodbye.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },

  {
    "id": "wg_gift_greet",
    "message": "Travelers' goods! Portable stoves, fuel charges, lanterns, sundries. Whatever you forgot to pack, I likely have it.",
    "replies": [
      {"text": "Show me your wares.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_gift"},
      {"text": "Goodbye.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },

  {
    "id": "wg_butler_greet",
    "message": "Good day, master. Reginald, at your service. Should you require provisions from the market, I shall fetch them at a 20% discount - my standing arrangement with the merchants. Where shall I run today?",
    "requires": [{"requireType": "inventory_kept", "id": "wg_deed_home4"}],
    "replies": [
      {"text": "Fetch me cloth and sewing supplies.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_butler_seamstress"},
      {"text": "Fetch me kitchen ingredients.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_butler_grocer"},
      {"text": "Fetch me fresh produce.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_butler_market"},
      {"text": "Fetch me weapon ingots.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_butler_weaponer"},
      {"text": "Fetch me armor and ring stock.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_butler_armorer"},
      {"text": "Fetch me traveler's goods.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_butler_gift"},
      {"text": "Fetch me seeds.", "next_phrase_id": "X_SHOP", "shop": "wg_shop_butler_farmer"},
      {"text": "That will be all, Reginald.", "next_phrase_id": "X_END_CONVERSATION"}
    ]
  },

