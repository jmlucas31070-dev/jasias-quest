    "showInLog": 1,
    "stages": [
      {
        "progress": 10,
        "logText": "You agreed to silence the mill in the Castle Region — distinct from any task Sunny is said to have done there.",
        "rewardExperience": 100
      },
      {
        "progress": 100,
        "logText": "Done. The folk of the Castle Region thank you.",
        "rewardExperience": 400,
        "finishesQuest": 1
      }
    ]
  },
  {
    "id": "jq_quest_main",
    "name": "@string/jq_quest_main_name",
    "showInLog": 1,
    "stages": [
      {
        "progress": 1,
        "logText": "Maid Maelyn caught me at the door of my home and begged me, in the King's name, to find my sister Sunny — gone these long weeks."
      },
      {
        "progress": 10,
        "logText": "Father (King Ozzy) and Mother (Queen Nymph) confirmed Sunny vanished after speaking with a guard in the lower cells. I should start at the prison."
      },
      {
        "progress": 20,
        "logText": "The prison guard told me Sunny asked after a witch's hut in the forest. Apparently he traded the address for a date with the head cook."
      },
      {
        "progress": 30,
        "logText": "I spoke with the witch Morwenna. She trained Sunny — but only after Sunny stole back her wand from the city's thieves."
      },
      {
        "progress": 40,
        "logText": "I retraced Sunny's path through the city's thieves and recovered the wand from their guild house."
      },
      {
        "progress": 45,
        "logText": "Morwenna confirmed Sunny earned her magic and rode out with three companions: Steve, Cara, and Sam."
      },
      {
        "progress": 50,
        "logText": "I have begun gathering the party's tale — twelve adventures across the world. Each clue brings Sunny closer."
      },
      {
        "progress": 60,
        "logText": "Steve, Cara and Sam each told their share. The party broke up at Semos Mountain after Steve tried to take a cloak Sunny had claimed."
      },
      {
        "progress": 70,
        "logText": "In Semos I learned Sunny vanished into the drow caves under the mountain wearing the cloak of invisibility."
      },
      {
        "progress": 75,
        "logText": "The drow sentry let me pass — once I had spoken to several drow with grievances of their own."
      },
      {
        "progress": 80,
        "logText": "Matron Lloth granted me her returning ring. She told me Sunny had walked further still — into the dragon halls of the volcano."
      },
      {
        "progress": 85,
        "logText": "I won the trust of all twelve dragon courts and bear the Dragonlords' Sigil."
      },
      {
        "progress": 90,
        "logText": "I climbed the mountain top. Sunny built a small world here — bound to a ring she lost. The tent guard at the drow cave will help me find it."
      },
      {
        "progress": 95,
        "logText": "I recovered the Ring of the Tent World. The tent guard let me into the clearing inside."
      },
      {
        "progress": 98,
        "logText": "I served all seven moon-drow elders. They have summoned a council. Sunny will be there."
      },
      {
        "progress": 100,
        "logText": "I found Sunny. She did not need rescuing — only finding. We are going home together.",
        "finishesQuest": 1,
        "rewardExperience": 25000
      }
    ]
  },
