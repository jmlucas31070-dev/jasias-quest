    "nodes": [
      {
        "id": "node_start",
        "text": "A round-cheeked baby in a white sash and tiny top hat toddles up to you. The sash reads '0'. It giggles and holds out a miniature party horn.",
        "replies": [
          { "text": "Happy New Year, little one!", "nextNode": "node_happy" },
          { "text": "What are you doing here?",    "nextNode": "node_explain" },
          { "text": "Goodbye.",                    "nextNode": null }
        ]
      },
      {
        "id": "node_happy",
        "text": "The baby claps its tiny hands and blows the party horn with glee. A warm glow washes over you — the blessing of a fresh start.",
        "replies": [
          {
            "text": "Thank you!",
            "nextNode": null,
            "giveActorCondition": "ac_newyears_blessing"
          }
        ]
      },
      {
        "id": "node_explain",
        "text": "The baby points skyward at invisible fireworks, then at you, then blows the party horn. It seems to be celebrating a new beginning.",
        "replies": [
          { "text": "Of course — Happy New Year!", "nextNode": "node_happy" },
          { "text": "Goodbye.",                    "nextNode": null }
        ]
      }
    ]
  },

