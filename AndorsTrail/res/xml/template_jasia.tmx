 <!-- ═══════════════════════════════════════════════════════════════════
      MAPEVENTS — exits spanning full sides of the 32×32 (1024px) map
      Replace destinationMapId / destinationX / destinationY with the
      real target map coordinates before use.
      Map pixel dimensions: 1024 × 1024  (32 tiles × 32 px each)
      Exit strip height/width = 32 px (1 tile row/column)
      ═══════════════════════════════════════════════════════════════════ -->
 <objectgroup id="8" name="Mapevents">

  <!-- NORTH exit — full top edge, player arrives near south of destination -->
  <object id="100" name="exit_north" type="MapChange" x="0" y="0" width="1024" height="32">
   <properties>
    <property name="destinationMapId" value="REPLACE_MAP_NORTH"/>
    <property name="destinationX" value="0"/>
    <property name="destinationY" value="30"/>
    <property name="place" value="north"/>
   </properties>
  </object>

  <!-- SOUTH exit — full bottom edge, player arrives near north of destination -->
  <object id="101" name="exit_south" type="MapChange" x="0" y="992" width="1024" height="32">
   <properties>
    <property name="destinationMapId" value="REPLACE_MAP_SOUTH"/>
    <property name="destinationX" value="0"/>
    <property name="destinationY" value="1"/>
    <property name="place" value="south"/>
   </properties>
  </object>

  <!-- EAST exit — full right edge, player arrives near west of destination -->
  <object id="102" name="exit_east" type="MapChange" x="992" y="0" width="32" height="1024">
   <properties>
    <property name="destinationMapId" value="REPLACE_MAP_EAST"/>
    <property name="destinationX" value="1"/>
    <property name="destinationY" value="0"/>
    <property name="place" value="east"/>
   </properties>
  </object>

  <!-- WEST exit — full left edge, player arrives near east of destination -->
  <object id="103" name="exit_west" type="MapChange" x="0" y="0" width="32" height="1024">
   <properties>
    <property name="destinationMapId" value="REPLACE_MAP_WEST"/>
    <property name="destinationX" value="30"/>
    <property name="destinationY" value="0"/>
    <property name="place" value="west"/>
   </properties>
  </object>

 </objectgroup>

