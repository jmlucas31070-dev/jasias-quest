 <!-- ═══════════════════════════════════════════════════════════════════
      KEYS_DOOR — locked door with full interaction set:
        • Use a key from inventory  (conversationId handles this)
        • Pick the lock (Thief class, lockpicks consumed per attempt)
        • Bash with a shield (Fighter class)
      conversationId references "door_approach" in conversationlist_door.json.

      LockedDoor  — blocks movement; player must interact to pass.
      UnlockDoor  — an alternate interactable that unlocks with a key
                    without consuming it (guard / caretaker scenario).
      ═══════════════════════════════════════════════════════════════════ -->
 <objectgroup id="11" name="Keys_door">

  <!--
    LOCKED DOOR
    Place this object on the tile that visually shows the closed door.
    The conversation "door_approach" presents three methods:
      1. Unlock with a key item (requireItem: "REPLACE_KEY_ID")
      2. Lockpick (thief only — crude 20%, standard 50%, masterwork 85%)
      3. Bash (fighter only — cloth shield 30%, metal shield 75%)
    Set destinationMapId to the room/area behind the door.
  -->
  <object id="116" name="LockedDoor" type="interactable" x="496" y="496" width="32" height="32">
   <properties>
    <property name="conversationId" value="door_approach"/>
    <property name="isLocked" value="true"/>
    <property name="requireItem" value="REPLACE_KEY_ID"/>
    <property name="destinationMapId" value="REPLACE_INNER_MAP"/>
    <property name="destinationX" value="15"/>
