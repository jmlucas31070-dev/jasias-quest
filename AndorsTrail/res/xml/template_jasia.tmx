 <!-- ═══════════════════════════════════════════════════════════════════
      REPLACE_NEWYEARS — New Year holiday event
      Runs from Dec 31 (offset -1) to Jan 1 (offset +1).
      holidayID "newyears" activates this layer group in the engine.

      Two event triggers are placed here covering the whole map:
        1. newyears_festival_start — marks the holiday active / gives blessing
        2. newyears_layer_swap     — swaps Ground/Objects/Above _replace layers
                                     in when the holiday is active

      The three _replace tile layers (Ground_replace, Objects_replace,
      Above_replace) should be painted with the seasonal decoration art.
      Spawn_replace (below) spawns the New Years Baby NPC.
      ═══════════════════════════════════════════════════════════════════ -->
 <objectgroup id="15" name="Replace_newyears">
  <properties>
   <property name="musicID" value="music_newyears_festival"/>
   <property name="ambientLightOnEnter" value="255"/>
   <property name="mapTitle" value="New Year Celebration"/>
   <property name="holidayID" value="newyears"/>
   <property name="eventStartOffset" value="-1"/>
   <property name="eventEndOffset" value="1"/>
  </properties>

  <!-- Holiday activation trigger — whole-map area -->
  <object id="133" name="newyears_festival_start" type="EventTrigger" x="0" y="0" width="1024" height="1024">
   <properties>
    <property name="id" value="newyears_festival_start"/>
    <property name="type" value="holidayEvent"/>
    <property name="scriptID" value="event_newyears"/>
   </properties>
  </object>

  <!-- Layer-swap trigger — activates _replace layers during the holiday -->
  <object id="134" name="newyears_layer_swap" type="EventTrigger" x="0" y="0" width="1024" height="1024">
   <properties>
    <property name="id" value="newyears_layer_swap"/>
    <property name="type" value="layerReplace"/>
    <property name="scriptID" value="layer_swap_newyears"/>
   </properties>
  </object>

 </objectgroup>

